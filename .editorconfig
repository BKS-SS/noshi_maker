# EditorConfig is awesome: https://EditorConfig.org
root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
# tab_width = 4
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

[*.{bat,cmd}]
indent_size = 2
end_of_line = crlf
charset = unset

[*.ps1]
indent_size = 2
charset = utf-8-bom

[*.sh]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[*.html]
indent_size = 2

[*.css]
indent_size = 2

[*.js]
indent_size = 2

[*.php]
indent_size = 2

[*.toml]
indent_size = 2

[*.json]
indent_size = 2

[*.yml]
indent_size = 2

[*.yaml]
indent_size = 2

[*.py]
indent_size = 4

[*.rs]
indent_size = 2

[*.c]
indent_size = 2

[*.cpp]
indent_size = 2

[*.cs]
indent_size = 2

[*.go]
indent_size = 2

[*.java]
indent_size = 4

[*.lua]
indent_size = 2

[*.rb]
indent_size = 2

[*.swift]
indent_size = 2

[*.kt]
indent_size = 2
